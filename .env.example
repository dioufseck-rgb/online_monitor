# Copy this to `.env` and fill in your real values.
# `.env` is gitignored — it should never be committed.

# --- LLM provider (pick one) ---

# Gemini (personal)
GEMINI_API_KEY=

# Azure OpenAI (enterprise)
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Anthropic (parity testing)
# ANTHROPIC_API_KEY=

# --- Sources ---

# Serper (https://serper.dev)
SERPER_API_KEY=

# Reddit (only needed if reddit source enabled in config — post-approval)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
