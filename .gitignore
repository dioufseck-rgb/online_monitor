# Secrets — NEVER commit
.env
.env.local
.env.*.local
*.pem
*.key

# Local config (the example is committed; real config is not)
config/config.yaml
config/config.local.yaml

# Local data
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# Generated reports — keep the directory but not the contents
reports/*.md
!reports/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
